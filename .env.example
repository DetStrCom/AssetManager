# IT Asset Manager — Environment Variables
# Copy this file to .env and fill in the values.

# Required in production (FLASK_ENV=production). 
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Set to "production" for production deployments.
# Omit or set to "development" for local development.
FLASK_ENV=development

# Database connection string.
# Defaults to SQLite if not set: sqlite:///asset_management.db
# For PostgreSQL: postgresql://user:password@localhost:5432/asset_management
DATABASE_URL=
